<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Staff Login | SCADA Tech</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    .login-page {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background: linear-gradient(135deg, #0b0f1a, #1a0137);
      padding: 20px;
    }

    .login-container {
      width: 100%;
      max-width: 500px;
      background: rgba(30, 20, 60, 0.9);
      border-radius: 16px;
      padding: 40px;
      box-shadow: 0 0 20px rgba(155, 81, 224, 0.3);
      border-left: 5px solid #9b51e0;
    }

    .login-container h2 {
      color: #9b51e0;
      text-align: center;
      margin-bottom: 30px;
      font-size: 2rem;
    }

    .login-form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .login-form input[type="text"],
    .login-form input[type="password"] {
      width: 100%;
      padding: 14px;
      border-radius: 8px;
      border: 1px solid #444;
      background: #1f1a30;
      color: #e0e0e0;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    .login-form input:focus {
      outline: none;
      border-color: #00e0ff;
      box-shadow: 0 0 10px #00e0ff;
    }

    .login-form button {
      width: 100%;
      padding: 14px;
      background: #9b51e0;
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: bold;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .login-form button:hover {
      background: #a14fe4;
      box-shadow: 0 0 12px #9b51e0;
    }

    .error-message {
      color: #ff4d4d;
      background: rgba(255, 77, 77, 0.1);
      padding: 10px;
      border-radius: 6px;
      margin-bottom: 15px;
      text-align: center;
      border-left: 3px solid #ff4d4d;
    }

    .back-link {
      text-align: center;
      margin-top: 20px;
      color: #ccc;
    }

    .back-link a {
      color: #00e0ff;
      font-weight: 500;
    }

    .back-link a:hover {
      text-shadow: 0 0 6px #00e0ff;
    }
  </style>
</head>

<body class="login-page">
  <div class="login-container">
    <h2>Staff Login</h2>

    <% if (error) { %>
      <div class="error-message"><%= error %></div>
    <% } %>

    <form class="login-form" action="/auth/login" method="POST">
      <input type="text" name="username" placeholder="Username" required>
      <input type="password" name="password" placeholder="Password" required>
      <button type="submit">Login</button>
    </form>

    <div class="back-link">
      <a href="/">← Back to Home</a>
    </div>
  </div>
</body>
</html>
